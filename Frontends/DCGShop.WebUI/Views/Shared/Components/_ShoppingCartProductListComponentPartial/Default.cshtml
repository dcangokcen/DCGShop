@model List<BasketItemDto>

@{
    var code = Context.Request.Query["code"].ToString();
    var discountRate = Context.Request.Query["discountRate"].ToString();
}

<div class="col-lg-8 table-responsive mb-5">
    <table class="table table-light table-borderless table-hover text-center mb-0">
        <thead class="thead-dark">
            <tr>
                <th>Ürün</th>
                <th>Fiyat</th>
                <th>Miktar</th>
                <th>Toplam</th>
                <th>Kaldır</th>
            </tr>
        </thead>
        <tbody class="align-middle">
            @foreach (var item in Model)
            {
                decimal x = item.Price * item.Quantity;

                <tr>
                    <td class="align-middle">
                        <img src="@item.ProductImageUrl" alt="" style="width: 50px; height:60px;">
                        @item.ProductName
                    </td>

                    <td class="align-middle">@item.Price.ToString("N2") ₺</td>

                    <td class="align-middle">
                        <div class="input-group quantity mx-auto" style="width: 100px;">
                            <div class="input-group-btn">
                                <a asp-controller="ShoppingCart"
                                   asp-action="DecreaseBasketItemQuantity"
                                   asp-route-id="@item.ProductId"
                                   asp-route-code="@code"
                                   asp-route-discountRate="@discountRate"
                                   class="btn btn-sm btn-primary">
                                    <i class="fa fa-minus"></i>
                                </a>
                            </div>

                            <input type="text"
                                   class="form-control form-control-sm bg-secondary border-0 text-center"
                                   value="@item.Quantity"
                                   readonly>

                            <div class="input-group-btn">
                                <a asp-controller="ShoppingCart"
                                   asp-action="IncreaseBasketItemQuantity"
                                   asp-route-id="@item.ProductId"
                                   asp-route-code="@code"
                                   asp-route-discountRate="@discountRate"
                                   class="btn btn-sm btn-primary">
                                    <i class="fa fa-plus"></i>
                                </a>
                            </div>
                        </div>
                    </td>

                    <td class="align-middle">@x.ToString("N2") ₺</td>

                    <td class="align-middle">
                        <a asp-controller="ShoppingCart"
                           asp-action="RemoveBasketItem"
                           asp-route-id="@item.ProductId"
                           asp-route-code="@code"
                           asp-route-discountRate="@discountRate"
                           class="btn btn-sm btn-danger">
                            <i class="fa fa-times"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>