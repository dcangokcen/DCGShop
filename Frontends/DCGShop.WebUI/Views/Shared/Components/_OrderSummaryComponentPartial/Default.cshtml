@model BasketTotalDto

<div class="bg-light p-30 mb-5">
    <div class="border-bottom">
        <h6 class="mb-3">Sipariş Listesi</h6>
        @foreach (var item in Model.BasketItems)
        {
            <div class="d-flex justify-content-between">
                @{
                    decimal itemTotalPrice = item.Price * item.Quantity;
                }
                <p>@item.ProductName x @item.Quantity</p>
                <p>@itemTotalPrice ₺</p>
            </div>
        }
    </div>
    <div class="border-bottom pt-3 pb-2">
        <div class="d-flex justify-content-between mb-3">
            <h6>Toplam</h6>
            <h6>@Model.TotalPrice ₺</h6>
        </div>
        <div class="d-flex justify-content-between">
            <h6 class="font-weight-medium">Kargo Ücreti</h6>
            <h6 class="font-weight-medium">39,90 ₺</h6>
        </div>
    </div>
    @{
        decimal total = Model.TotalPrice + 39.90m;
    }
    <div class="pt-2">
        <div class="d-flex justify-content-between mt-2">
            <h5>Ödemecek Tutar</h5>
            <h5>@total</h5>
        </div>
    </div>
</div>
