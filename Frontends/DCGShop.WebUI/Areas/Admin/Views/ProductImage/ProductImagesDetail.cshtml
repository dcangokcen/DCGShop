@model UpdateProductImageDto

@{
    ViewData["Title"] = "ProductImagesDetail";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">

        <div class="col-md-12">
            <div class="chart-box">
                <h4>Ürün Görsel Güncelleme İşlemleri</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">

                    <form method="post">
                        <input type="hidden" asp-for="ProductImageId" />
                        <input type="hidden" asp-for="ProductId" />
                        <label>Görsel 1</label>
                        <input type="text" class="form-control" asp-for="Images1" />
                        <br />
                        <label>Görsel 2</label>
                        <input type="text" class="form-control" asp-for="Images2" />
                        <br />
                        <label>Görsel 3</label>
                        <input type="text" class="form-control" asp-for="Images3" />
                        <br />
                        <label>Görsel 4</label>
                        <input type="text" class="form-control" asp-for="Images4" />
                        <br />
                        <button class="btn btn-success">Görselleri Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>



